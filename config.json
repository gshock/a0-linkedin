{
  "title": "LinkedIn Plugin",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "title": "Enable plugin",
      "default": true
    },
    "active_profile": {
      "type": "string",
      "title": "Active Profile",
      "default": "personal_app",
      "description": "Runtime convenience profile. Chat tools may still route per request based on explicit personal or organization intent."
    },
    "linkedin": {
      "type": "object",
      "title": "Shared / Effective LinkedIn Settings",
      "description": "Top-level effective or shared settings container used for runtime compatibility. Profile-specific credentials should be configured under profiles.personal_app.linkedin and profiles.org_app.linkedin.",
      "properties": {
        "mode": {
          "type": "string",
          "title": "Mode",
          "enum": [
            "api"
          ],
          "default": "api"
        },
        "api_base_url": {
          "type": "string",
          "title": "API Base URL",
          "default": "https://api.linkedin.com"
        },
        "access_token": {
          "type": "string",
          "title": "Access Token",
          "default": ""
        },
        "person_urn": {
          "type": "string",
          "title": "Person URN",
          "default": ""
        },
        "organization_urn": {
          "type": "string",
          "title": "Organization URN",
          "default": ""
        },
        "organization_urns": {
          "type": "array",
          "title": "Organization URNs",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "scopes": {
          "type": "array",
          "title": "Scopes",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "default_target": {
          "type": "string",
          "title": "Default Target",
          "enum": [
            "personal",
            "organization"
          ],
          "default": "personal"
        },
        "linkedin_version": {
          "type": "string",
          "title": "LinkedIn Version",
          "default": "202601"
        },
        "default_visibility": {
          "type": "string",
          "title": "Default Visibility",
          "enum": [
            "PUBLIC",
            "CONNECTIONS",
            "LOGGED_IN"
          ],
          "default": "PUBLIC"
        },
        "dry_run": {
          "type": "boolean",
          "title": "Dry Run",
          "default": true
        },
        "timeout_seconds": {
          "type": "integer",
          "title": "Timeout Seconds",
          "default": 30,
          "minimum": 5,
          "maximum": 120
        },
        "user_agent": {
          "type": "string",
          "title": "User Agent",
          "default": "AgentZero-LinkedIn-Plugin/0.2.0"
        }
      }
    },
    "profiles": {
      "type": "object",
      "title": "Named LinkedIn Profiles",
      "description": "Store separate app credentials and defaults for personal and organization workflows.",
      "default": {
        "personal_app": {
          "label": "Personal App",
          "description": "Credentials and defaults for posting under the user's personal LinkedIn profile.",
          "linkedin": {
            "mode": "api",
            "api_base_url": "https://api.linkedin.com",
            "access_token": "",
            "person_urn": "",
            "organization_urn": "",
            "organization_urns": [],
            "scopes": [
              "w_member_social"
            ],
            "default_target": "personal",
            "linkedin_version": "202601",
            "default_visibility": "PUBLIC",
            "dry_run": true,
            "timeout_seconds": 30,
            "user_agent": "AgentZero-LinkedIn-Plugin/0.2.0"
          }
        },
        "org_app": {
          "label": "Organization App",
          "description": "Credentials and defaults for posting under a LinkedIn organization/company page.",
          "linkedin": {
            "mode": "api",
            "api_base_url": "https://api.linkedin.com",
            "access_token": "",
            "person_urn": "",
            "organization_urn": "",
            "organization_urns": [],
            "scopes": [
              "w_organization_social",
              "r_organization_social"
            ],
            "default_target": "organization",
            "linkedin_version": "202601",
            "default_visibility": "PUBLIC",
            "dry_run": true,
            "timeout_seconds": 30,
            "user_agent": "AgentZero-LinkedIn-Plugin/0.2.0"
          }
        }
      }
    }
  }
}
